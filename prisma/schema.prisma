generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ClientStatus {
  lead
  active
  inactive
  archived
}

enum JobStatus {
  pending
  quoted
  approved
  production
  painted
  delivered
  cancelled
}

enum JobPriority {
  low
  normal
  high
  urgent
}

enum QuoteStatus {
  draft
  sent
  approved
  rejected
  expired
  cancelled
}

enum PaymentMethod {
  cash
  transfer
  card
  mercado_pago
  other
}

enum IncomeStatus {
  pending
  paid
  cancelled
  refunded
}

enum AgendaType {
  visit
  measurement
  production
  painting
  delivery
  payment
  reminder
  other
}

enum AgendaStatus {
  scheduled
  completed
  cancelled
  postponed
}

enum NotificationType {
  info
  success
  warning
  error
  reminder
}

enum ContactMessageStatus {
  new
  contacted
  converted_to_client
  dismissed
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("roles")
}

model User {
  id             String        @id @default(uuid())
  name           String
  email          String        @unique
  passwordHash   String
  roleId         String
  role           Role          @relation(fields: [roleId], references: [id], onDelete: Restrict)
  isActive       Boolean       @default(true)
  lastLoginAt    DateTime?
  refreshTokens  RefreshToken[]
  createdJobs    Job[]         @relation("JobCreatedBy")
  createdQuotes  Quote[]       @relation("QuoteCreatedBy")
  createdIncomes Income[]      @relation("IncomeCreatedBy")
  createdExpenses Expense[]    @relation("ExpenseCreatedBy")
  createdEvents  AgendaEvent[] @relation("AgendaCreatedBy")
  assignedEvents AgendaEvent[] @relation("AgendaAssignedTo")
  notifications  Notification[]
  auditLogs      AuditLog[]
  uploadedFiles  File[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@map("refresh_tokens")
}

model Client {
  id              String              @id @default(uuid())
  fullName        String
  phone           String
  email           String?
  address         String?
  city            String?
  notes           String?
  source          String?
  status          ClientStatus         @default(lead)
  jobs            Job[]
  quotes          Quote[]
  incomes         Income[]
  agendaEvents    AgendaEvent[]
  contactMessages ContactMessage[]
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([fullName])
  @@index([phone])
  @@index([status])
  @@map("clients")
}

model Job {
  id                    String        @id @default(uuid())
  clientId              String
  client                Client        @relation(fields: [clientId], references: [id], onDelete: Restrict)
  title                 String
  description           String?
  serviceType           String?
  status                JobStatus     @default(pending)
  priority              JobPriority   @default(normal)
  estimatedStartDate    DateTime?
  estimatedDeliveryDate DateTime?
  realStartDate         DateTime?
  realDeliveryDate      DateTime?
  estimatedPrice        Decimal?      @db.Decimal(12, 2)
  finalPrice            Decimal?      @db.Decimal(12, 2)
  internalNotes         String?
  createdById           String?
  createdBy             User?         @relation("JobCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  quotes                Quote[]
  incomes               Income[]
  expenses              Expense[]
  agendaEvents          AgendaEvent[]
  files                 File[]
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt

  @@index([clientId])
  @@index([status])
  @@index([createdById])
  @@map("jobs")
}

model Quote {
  id             String        @id @default(uuid())
  quoteNumber    String        @unique
  clientId       String
  client         Client        @relation(fields: [clientId], references: [id], onDelete: Restrict)
  jobId          String?
  job            Job?          @relation(fields: [jobId], references: [id], onDelete: SetNull)
  title          String
  description    String?
  status         QuoteStatus   @default(draft)
  materialsCost  Decimal       @default(0) @db.Decimal(12, 2)
  laborCost      Decimal       @default(0) @db.Decimal(12, 2)
  paintCost      Decimal       @default(0) @db.Decimal(12, 2)
  extraCost      Decimal       @default(0) @db.Decimal(12, 2)
  subtotal       Decimal       @default(0) @db.Decimal(12, 2)
  discount       Decimal       @default(0) @db.Decimal(12, 2)
  profitMargin   Decimal       @default(0) @db.Decimal(6, 2)
  total          Decimal       @default(0) @db.Decimal(12, 2)
  validUntil     DateTime?
  sentAt         DateTime?
  approvedAt     DateTime?
  rejectedAt     DateTime?
  pdfUrl         String?
  internalNotes  String?
  createdById    String?
  createdBy      User?         @relation("QuoteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  items          QuoteItem[]
  incomes        Income[]
  files          File[]
  pdfDocuments   PdfDocument[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([clientId])
  @@index([jobId])
  @@index([status])
  @@map("quotes")
}

model QuoteItem {
  id          String   @id @default(uuid())
  quoteId     String
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  name        String
  description String?
  quantity    Decimal  @default(1) @db.Decimal(12, 2)
  unitPrice   Decimal  @default(0) @db.Decimal(12, 2)
  total       Decimal  @default(0) @db.Decimal(12, 2)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([quoteId])
  @@map("quote_items")
}

model Income {
  id            String        @id @default(uuid())
  clientId      String?
  client        Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  jobId         String?
  job           Job?          @relation(fields: [jobId], references: [id], onDelete: SetNull)
  quoteId       String?
  quote         Quote?        @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  title         String
  amount        Decimal       @db.Decimal(12, 2)
  paymentMethod PaymentMethod @default(other)
  status        IncomeStatus  @default(pending)
  paidAt        DateTime?
  notes         String?
  createdById   String?
  createdBy     User?         @relation("IncomeCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@index([clientId])
  @@index([jobId])
  @@index([quoteId])
  @@index([status])
  @@map("incomes")
}

model Expense {
  id            String         @id @default(uuid())
  title         String
  category      String
  amount        Decimal        @db.Decimal(12, 2)
  paymentMethod PaymentMethod?
  expenseDate   DateTime
  supplier      String?
  jobId         String?
  job           Job?           @relation(fields: [jobId], references: [id], onDelete: SetNull)
  notes         String?
  createdById   String?
  createdBy     User?          @relation("ExpenseCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([category])
  @@index([expenseDate])
  @@index([jobId])
  @@map("expenses")
}

model AgendaEvent {
  id           String       @id @default(uuid())
  title        String
  description  String?
  type         AgendaType   @default(other)
  status       AgendaStatus @default(scheduled)
  startAt      DateTime
  endAt        DateTime?
  clientId     String?
  client       Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  jobId        String?
  job          Job?         @relation(fields: [jobId], references: [id], onDelete: SetNull)
  assignedToId String?
  assignedTo   User?        @relation("AgendaAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  reminderAt   DateTime?
  createdById  String?
  createdBy    User?        @relation("AgendaCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([startAt])
  @@index([status])
  @@index([clientId])
  @@index([jobId])
  @@map("agenda_events")
}

model GalleryItem {
  id             String   @id @default(uuid())
  title          String
  slug           String   @unique
  description    String?
  category       String?
  mainImageUrl   String
  beforeImageUrl String?
  afterImageUrl  String?
  isFeatured     Boolean  @default(false)
  isPublished    Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([category])
  @@index([isPublished])
  @@index([isFeatured])
  @@map("gallery_items")
}

model ContactMessage {
  id              String               @id @default(uuid())
  fullName        String
  phone           String
  email           String?
  message         String
  serviceInterest String?
  status          ContactMessageStatus @default(new)
  clientId        String?
  client          Client?              @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([status])
  @@index([phone])
  @@map("contact_messages")
}

model Notification {
  id         String           @id @default(uuid())
  userId     String?
  user       User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String
  message    String
  type       NotificationType @default(info)
  entityType String?
  entityId   String?
  isRead     Boolean          @default(false)
  readAt     DateTime?
  createdAt  DateTime         @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([entityType, entityId])
  @@map("notifications")
}

model BusinessSettings {
  id                       String   @id @default(uuid())
  businessName             String
  publicName               String
  phone                    String
  whatsapp                 String
  email                    String
  address                  String
  city                     String
  province                 String
  country                  String
  logoUrl                  String?
  instagramUrl             String?
  facebookUrl              String?
  googleMapsUrl            String?
  openingHours             Json?
  quoteDefaultValidityDays Int      @default(15)
  defaultProfitMargin      Decimal  @default(0) @db.Decimal(6, 2)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@map("business_settings")
}

model File {
  id           String   @id @default(uuid())
  url          String
  filename     String?
  mimeType     String?
  size         Int?
  entityType   String?
  entityId     String?
  jobId        String?
  job          Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)
  quoteId      String?
  quote        Quote?   @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  uploadedById String?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  @@index([entityType, entityId])
  @@index([jobId])
  @@index([quoteId])
  @@map("files")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  entityType String?
  entityId   String?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

model PdfDocument {
  id        String   @id @default(uuid())
  quoteId   String?
  quote     Quote?   @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  fileName  String
  filePath  String
  publicUrl String
  token     String   @unique
  createdAt DateTime @default(now())

  @@index([quoteId])
  @@map("pdf_documents")
}

model MessageLog {
  id          String   @id @default(uuid())
  type        String
  provider    String?
  destination String
  payload     Json
  status      String
  createdAt   DateTime @default(now())

  @@index([type])
  @@index([status])
  @@map("message_logs")
}

model AiSuggestion {
  id        String   @id @default(uuid())
  type      String
  input     Json
  output    Json
  createdAt DateTime @default(now())

  @@index([type])
  @@map("ai_suggestions")
}
