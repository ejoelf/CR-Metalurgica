generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ClientStatus {
  lead
  active
  inactive
  archived
}

enum JobStatus {
  pending
  quoted
  approved
  production
  painted
  delivered
  cancelled
}

enum JobPriority {
  low
  normal
  high
  urgent
}

enum QuoteStatus {
  draft
  sent
  approved
  rejected
  expired
  cancelled
}

enum PaymentMethod {
  cash
  transfer
  card
  mercado_pago
  other
}

enum IncomeStatus {
  pending
  paid
  cancelled
  refunded
}

enum AgendaType {
  visit
  measurement
  production
  painting
  delivery
  payment
  reminder
  other
}

enum AgendaStatus {
  scheduled
  completed
  cancelled
  postponed
}

enum NotificationType {
  info
  success
  warning
  error
  reminder
}

enum ContactMessageStatus {
  new
  contacted
  converted_to_client
  dismissed
}

model Role {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("roles")
}

model User {
  id             String        @id @default(uuid())
  name           String
  username       String?       @unique
  email          String        @unique
  passwordHash   String
  roleId         String
  role           Role          @relation(fields: [roleId], references: [id], onDelete: Restrict)
  isActive       Boolean       @default(true)
  lastLoginAt    DateTime?
  refreshTokens  RefreshToken[]
  createdJobs    Job[]         @relation("JobCreatedBy")
  createdQuotes  Quote[]       @relation("QuoteCreatedBy")
  createdIncomes Income[]      @relation("IncomeCreatedBy")
  createdExpenses Expense[]    @relation("ExpenseCreatedBy")
  createdEvents  AgendaEvent[] @relation("AgendaCreatedBy")
  assignedEvents AgendaEvent[] @relation("AgendaAssignedTo")
  notifications  Notification[]
  auditLogs      AuditLog[]
  uploadedFiles  File[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@map("refresh_tokens")
}

model BusinessSettings {
  id                       String   @id @default(uuid())
  businessName             String   @default("CF Metal-Pintura")
  publicName               String?  @default("CF Metal Pintura")
  legalName                String?
  taxId                    String?
  email                    String?
  phone                    String?
  whatsapp                 String?
  address                  String?
  city                     String?
  province                 String?
  country                  String?  @default("Argentina")
  website                  String?
  logoUrl                  String?
  signatureUrl             String?
  instagramUrl             String?
  facebookUrl              String?
  googleMapsUrl            String?
  defaultTaxRate           Decimal  @default(21)
  defaultMargin            Decimal  @default(15)
  defaultProfitMargin      Decimal  @default(15)
  quoteValidityDays        Int      @default(15)
  quoteDefaultValidityDays Int      @default(15)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@map("business_settings")
}

model Client {
  id              String           @id @default(uuid())
  fullName        String
  phone           String
  email           String?
  address         String?
  city            String?
  taxId           String?
  clientType      String?          @default("particular")
  source          String?
  notes           String?
  status          ClientStatus     @default(lead)
  jobs            Job[]
  quotes          Quote[]
  incomes         Income[]
  expenses        Expense[]
  agendaEvents    AgendaEvent[]
  contactMessages ContactMessage[]
  files           File[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@map("clients")
}

model Job {
  id             String       @id @default(uuid())
  clientId       String
  client         Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  serviceType    String?
  status         JobStatus    @default(pending)
  priority       JobPriority  @default(normal)
  estimatedPrice Decimal?
  finalPrice     Decimal?
  paidAmount     Decimal      @default(0)
  acceptedAt     DateTime?
  budgetedAt     DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  deliveredAt    DateTime?
  dueDate        DateTime?
  internalNotes  String?
  createdById    String?
  createdBy      User?        @relation("JobCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  quotes         Quote[]
  incomes        Income[]
  expenses       Expense[]
  agendaEvents   AgendaEvent[]
  files          File[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("jobs")
}

model Quote {
  id                    String      @id @default(uuid())
  quoteNumber           String      @unique
  clientId              String?
  client                Client?     @relation(fields: [clientId], references: [id], onDelete: SetNull)
  jobId                 String?
  job                   Job?        @relation(fields: [jobId], references: [id], onDelete: SetNull)
  title                 String
  description           String?
  status                QuoteStatus @default(draft)
  recipientName         String?
  recipientCompany      String?
  recipientContactName  String?
  recipientPhone        String?
  recipientEmail        String?
  recipientTaxId        String?
  recipientAddress      String?
  recipientCity         String?
  recipientProvince     String?
  recipientAdminAddress String?
  workObject            String?
  workLocation          String?
  includedTasks         String?
  excludedTasks         String?
  technicalNotes        String?
  paymentTerms          String?
  executionTime         String?
  warranty              String?
  commercialConditions  String?
  includeDigitalSignature Boolean   @default(false)
  materialsCost         Decimal     @default(0)
  laborCost             Decimal     @default(0)
  paintCost             Decimal     @default(0)
  extraCost             Decimal     @default(0)
  subtotal              Decimal     @default(0)
  discount              Decimal     @default(0)
  profitMargin          Decimal     @default(15)
  total                 Decimal     @default(0)
  validUntil            DateTime?
  sentAt                DateTime?
  approvedAt            DateTime?
  rejectedAt            DateTime?
  pdfUrl                String?
  internalNotes         String?
  createdById           String?
  createdBy             User?       @relation("QuoteCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  items                 QuoteItem[]
  pdfDocuments          PdfDocument[]
  incomes               Income[]
  expenses              Expense[]
  agendaEvents          AgendaEvent[]
  files                 File[]
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@map("quotes")
}

model QuoteItem {
  id          String   @id @default(uuid())
  quoteId     String
  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  name        String
  description String?
  quantity    Decimal  @default(1)
  unit         String?  @default("unidad")
  unitPrice   Decimal  @default(0)
  total       Decimal  @default(0)
  note        String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("quote_items")
}

model PdfDocument {
  id        String   @id @default(uuid())
  quoteId   String
  quote     Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  fileName  String
  fileUrl   String
  version   Int      @default(1)
  createdAt DateTime @default(now())

  @@map("pdf_documents")
}

model Income {
  id            String       @id @default(uuid())
  title         String
  description   String?
  amount        Decimal
  status        IncomeStatus @default(pending)
  paymentMethod String?
  paidAt        DateTime?
  clientId      String?
  client        Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  jobId         String?
  job           Job?         @relation(fields: [jobId], references: [id], onDelete: SetNull)
  quoteId       String?
  quote         Quote?       @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  createdById   String?
  createdBy     User?        @relation("IncomeCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@map("incomes")
}

model Expense {
  id            String   @id @default(uuid())
  title         String
  description   String?
  amount        Decimal
  category      String?
  paymentMethod String?
  expenseDate   DateTime @default(now())
  supplierName  String?
  clientId      String?
  client        Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  jobId         String?
  job           Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)
  quoteId       String?
  quote         Quote?   @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  createdById   String?
  createdBy     User?    @relation("ExpenseCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("expenses")
}

model AgendaEvent {
  id           String       @id @default(uuid())
  title        String
  description  String?
  type         AgendaType   @default(other)
  status       AgendaStatus @default(scheduled)
  startAt      DateTime
  endAt        DateTime?
  reminderAt   DateTime?
  location     String?
  clientId     String?
  client       Client?      @relation(fields: [clientId], references: [id], onDelete: SetNull)
  jobId        String?
  job          Job?         @relation(fields: [jobId], references: [id], onDelete: SetNull)
  quoteId      String?
  quote        Quote?       @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  assignedToId String?
  assignedTo   User?        @relation("AgendaAssignedTo", fields: [assignedToId], references: [id], onDelete: SetNull)
  createdById  String?
  createdBy    User?        @relation("AgendaCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@map("agenda_events")
}

model Notification {
  id         String           @id @default(uuid())
  userId     String?
  user       User?            @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String
  message    String
  type       NotificationType @default(info)
  isRead     Boolean          @default(false)
  readAt     DateTime?
  entityType String?
  entityId   String?
  createdAt  DateTime         @default(now())

  @@map("notifications")
}

model ContactMessage {
  id              String               @id @default(uuid())
  fullName        String
  phone           String
  email           String?
  message         String
  serviceInterest String?
  status          ContactMessageStatus @default(new)
  clientId        String?
  client          Client?              @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@map("contact_messages")
}

model GalleryItem {
  id             String   @id @default(uuid())
  title          String
  slug           String   @unique
  description    String?
  category       String?
  mainImageUrl   String
  beforeImageUrl String?
  afterImageUrl  String?
  isFeatured     Boolean  @default(false)
  isPublished    Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("gallery_items")
}

model File {
  id           String   @id @default(uuid())
  fileName     String
  fileUrl      String
  mimeType     String?
  sizeBytes    Int?
  entityType   String?
  entityId     String?
  clientId     String?
  client       Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  jobId        String?
  job          Job?     @relation(fields: [jobId], references: [id], onDelete: SetNull)
  quoteId      String?
  quote        Quote?   @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  uploadedById String?
  uploadedBy   User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())

  @@map("files")
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String
  entityType String
  entityId   String?
  oldValue   Json?
  newValue   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@map("audit_logs")
}
